# DroneMaker ALT repo ignore rules
# Keep source, documentation, CAD source files, and configuration templates.
# Ignore generated build products, local machine state, and bulky temporary exports.

# -----------------------------
# OS / editor clutter
# -----------------------------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
.idea/

# -----------------------------
# Logs and temporary files
# -----------------------------
*.log
*.tmp
*.temp
.cache/
tmp/
temp/

# -----------------------------
# Secrets / local environment
# -----------------------------
.env
.env.*
!.env.example
secrets/
credentials/
*.pem
*.key
*.crt
*.p12
*.pfx

# -----------------------------
# Arduino IDE / Arduino CLI
# -----------------------------
*.hex
*.elf
*.bin
*.map
*.eep
*.lss
*.sym
*.d
*.o
*.a
build/
build-*/
*.ino.cpp
.arduinoIDE/
arduino-cli.yaml

# Arduino local libraries may get huge; keep intentional project libraries under firmware/lib/
libraries/

# -----------------------------
# PlatformIO
# -----------------------------
.pio/
.pioenvs/
.piolibdeps/
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/tasks.json

# -----------------------------
# ESP-IDF / ESP32
# -----------------------------
sdkconfig.old
managed_components/
dependencies.lock
bootloader/
partition_table/
flasher_args.json
*.uf2

# Keep sdkconfig defaults/templates if intentionally committed
!sdkconfig.defaults
!sdkconfig.defaults.*

# -----------------------------
# Python helper scripts
# -----------------------------
__pycache__/
*.py[cod]
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/

# -----------------------------
# Node / web UI experiments
# -----------------------------
node_modules/
dist/
.next/
out/
coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------
# Firmware backup dumps
# -----------------------------
# Do not commit raw factory dumps unless intentionally archived/released.
firmware-backups/
*.flashdump
*.dump
*.img

# -----------------------------
# CAD / 3D printing generated exports
# -----------------------------
# Keep source CAD when useful: .step, .f3d, .fcstd, .scad, .blend, etc.
# STL/3MF files may be committed only when they are final/reference artifacts.
*.gcode
*.bgcode
*.gx
*.x3g
*.ctb
*.photon
*.fdg
*.lys

# Slicer project autosaves / backups
*.factory
*.bak
*.backup

# -----------------------------
# KiCad / electronics generated files
# -----------------------------
*-backups/
*.kicad_pcb-bak
*.sch-bak
fp-info-cache
sym-lib-table-bak

# -----------------------------
# Archives and downloaded packages
# -----------------------------
*.zip
*.7z
*.rar
*.tar
*.tar.gz
*.tgz

# -----------------------------
# Local scratch area
# -----------------------------
scratch/
local/
inbox/
